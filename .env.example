# Runtime
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# Required auth key for every REST + MCP request
# Generate with: openssl rand -hex 32
API_KEY=replace-with-a-long-random-key

# Optional CORS origin for browser clients
# CORS_ORIGIN=https://your-domain.com

# Coresignal API Key for data enrichment
CORESIGNAL_API_KEY=your-coresignal-api-key

# crawl4ai self-hosted service (docker compose up -d crawl4ai)
CRAWL4AI_BASE_URL=http://localhost:11235
OPENAI_API_KEY=your-openai-api-key

# GCP deploy settings
GCP_PROJECT_ID=your-gcp-project-id
CLOUD_RUN_SERVICE=ekas-mcps
CLOUD_RUN_REGION=us-central1
SECRET_PREFIX=ekas-mcps-

# Cost controls and runtime tuning for Cloud Run
CLOUD_RUN_ALLOW_UNAUTHENTICATED=false
CLOUD_RUN_MAX_INSTANCES=2
CLOUD_RUN_CONCURRENCY=40
CLOUD_RUN_TIMEOUT=60
CLOUD_RUN_MEMORY=512Mi
