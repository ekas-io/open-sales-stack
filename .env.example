# ── Open Sales Stack ─────────────────────────────────────────
# Shared config for all MCP servers.
# Copy to .env and fill in the values:
#   cp .env.example .env
#
# Per-package overrides: create a .env inside any package
# directory to override values for that package only.

# ── Shared (all MCPs) ───────────────────────────────────────

# Required — used by crawl4ai for LLM-based extraction
OPENAI_API_KEY=your-openai-api-key


# ── website-intel ───────────────────────────────────────────
# No additional env vars

# ── techstack-intel ─────────────────────────────────────────
# No additional env vars

# ── social-intel ────────────────────────────────────────────
# Optional — if set, uses programmatic login (headless).
# If not set, opens a browser window for manual LinkedIn login.
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# ── hiring-intel ────────────────────────────────────────────
# No additional env vars

# ── review-intel ────────────────────────────────────────────
# No additional env vars

# ── ad-intel ────────────────────────────────────────────────
# No additional env vars
