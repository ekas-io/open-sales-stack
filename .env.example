# ── Open Sales Stack ─────────────────────────────────────────
# Shared config for all MCP servers.
# Copy to .env and fill in the values:
#   cp .env.example .env
#
# Per-package overrides: create a .env inside any package
# directory to override values for that package only.

# ── Shared (all MCPs) ───────────────────────────────────────

# Required — used for LLM-based extraction
OPENAI_API_KEY=your-api-key


# ── website-intel ───────────────────────────────────────────
# No additional env vars

# ── techstack-intel ─────────────────────────────────────────
# No additional env vars

# ── social-intel ────────────────────────────────────────────
# Optional — if set, uses programmatic login (headless).
# If not set, opens a browser window for manual LinkedIn login.
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# ── hiring-intel ────────────────────────────────────────────
# Optional — proxy list for JobSpy (comma-separated)
# Useful for LinkedIn scraping at volume or geo-targeted searches.
# Format: user:pass@host:port or host:port
# JOBSPY_PROXIES=user:pass@proxy1.example.com:8080,user:pass@proxy2.example.com:8080

# Optional — CA certificate path for proxy SSL connections
# Only needed if your proxy or corporate network uses a custom CA.
# JOBSPY_CA_CERT=/path/to/ca-cert.pem

# ── review-intel ────────────────────────────────────────────
# No additional env vars

# ── ad-intel ────────────────────────────────────────────────
# No additional env vars
