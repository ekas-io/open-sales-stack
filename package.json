{
  "name": "ekas-mcps",
  "version": "0.1.0",
  "private": true,
  "description": "Personal sales-engine boilerplate with REST + MCP endpoints",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit && esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js --external:dotenv --external:express --external:cors --external:helmet --external:express-rate-limit --external:pino --external:pino-http --external:zod --external:zod-to-json-schema --external:@modelcontextprotocol/sdk",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "deploy": "bash scripts/deploy.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.1",
    "esbuild": "^0.27.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
